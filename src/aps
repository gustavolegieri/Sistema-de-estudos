function HM({sD,onT}){
  const st=new Date(2026,2,1),en=new Date(2026,10,30);
  const days=[];let d=new Date(st);while(d<=en){days.push(new Date(d));d.setDate(d.getDate()+1);}
  const pad=st.getDay();for(let i=0;i<pad;i++)days.unshift(null);
  const wks=[];for(let i=0;i<days.length;i+=7)wks.push(days.slice(i,i+7));
  const MN=['','','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov'];
  const mpos={};wks.forEach((w,wi)=>{const f=w.find(Boolean);if(f&&!mpos[f.getMonth()])mpos[f.getMonth()]=wi;});
  return <div>
    <div style={{display:'flex',gap:3,marginBottom:4,height:14,position:'relative'}}>
      {Object.entries(mpos).map(([m,wi])=><div key={m} style={{position:'absolute',left:wi*14,fontSize:9,color:C.tx2,fontFamily:C.fm,whiteSpace:'nowrap'}}>{MN[m]}</div>)}
    </div>
    <div style={{display:'flex',gap:3,overflowX:'auto',paddingBottom:4}}>
      {wks.map((w,wi)=><div key={wi} style={{display:'flex',flexDirection:'column',gap:3}}>
        {w.map((day,di)=>{
          if(!day)return<div key={di} style={{width:11,height:11}}/>;
          const k=day.toISOString().split('T')[0],h=sD[k]||0;
          const dow=day.getDay(),isW=dow>0&&dow<6;
          const bg=[C.bo,'rgba(0,230,118,.18)','rgba(0,230,118,.42)','rgba(0,230,118,.65)',C.g][Math.min(4,h)];
          return <div key={di} title={`${k}: ${h}h`} onClick={()=>onT(k)}
            style={{width:11,height:11,borderRadius:2,background:bg,cursor:'pointer',opacity:!isW&&h===0?.3:1,transition:'transform .1s'}}
            onMouseEnter={e=>e.target.style.transform='scale(1.4)'}
            onMouseLeave={e=>e.target.style.transform='scale(1)'}/>;
        })}
      </div>)}
    </div>
    <div style={{display:'flex',gap:5,alignItems:'center',marginTop:8}}>
      {['MENOS',C.bo,'rgba(0,230,118,.18)','rgba(0,230,118,.42)','rgba(0,230,118,.65)',C.g,'MAIS'].map((x,i)=>
        typeof x==='string'&&(x==='MENOS'||x==='MAIS')?<span key={i} style={{fontSize:9,color:C.tx2,fontFamily:C.fm}}>{x}</span>:<div key={i} style={{width:10,height:10,borderRadius:2,background:x}}/>
      )}
    </div>
  </div>;
}

// ═══ QUIZ ═══
function QuizMod({course,onClose,onSave}){
  const [ph,sPh]=useState('loading');
  const [qs,sQs]=useState([]);
  const [cur,sCur]=useState(0);
  const [sc,sSc]=useState(0);
  const [ch,sCh]=useState(null);
  useEffect(()=>{load();},[]);
  async function load(){
    try{
      const tx=await aiCall([{role:'user',content:`Crie 5 perguntas de múltipla escolha em português sobre "${course.name}". Tópicos: ${course.topics}. APENAS JSON sem markdown:\n{"questions":[{"q":"...","opts":["A) ...","B) ...","C) ...","D) ..."],"ans":"A","exp":"explicação"}]}`}],1000);
      const p=JSON.parse(tx.replace(/```json|```/g,'').trim());
      sQs(p.questions);sPh('quiz');
    }catch{sQs(JSON.parse(JSON.stringify(SQ[course.id]||SQ.default)));sPh('quiz');}
  }
  function ans(i){
    if(ch!==null)return;
    const ok=['A','B','C','D'][i]===qs[cur].ans;
    sCh(i);if(ok)sSc(s=>s+1);
  }
  function nxt(){
    if(cur+1>=qs.length){
      onSave(course.id,{score:sc+(ch!==null&&['A','B','C','D'][ch]===qs[cur].ans&&sc===sc?0:0),total:qs.length,date:new Date().toLocaleDateString('pt-BR')});
      sPh('result');
    }else{sCur(c=>c+1);sCh(null);}
  }
  const lt=['A','B','C','D'];
  const pct=qs.length?Math.round(sc/qs.length*100):0;
  const sc2=pct===100?C.g:pct>=60?C.c:pct>=40?C.a:C.r;
  return <Mod title={`QUIZ · ${course.name.slice(0,28)}...`} sub={course.plat} onClose={onClose} mw={600}>
    {ph==='loading'&&<div style={{textAlign:'center',padding:40}}><Sp sz={40}/><div style={{marginTop:14,fontFamily:C.fm,fontSize:11,color:C.tx2}}>Gerando perguntas com IA...</div></div>}
    {ph==='quiz'&&qs[cur]&&<div>
      <PBar val={(cur/qs.length)*100} cl={C.g} h={3} glow/>
      <div style={{fontFamily:C.fm,fontSize:10,color:C.tx2,letterSpacing:2,margin:'14px 0 8px'}}>PERGUNTA {cur+1}/{qs.length}</div>
      <div style={{fontSize:15,fontWeight:600,color:C.wh,lineHeight:1.5,marginBottom:18}}>{qs[cur].q}</div>
      {qs[cur].opts.map((op,i)=>{
        let bg=C.s3,bd=C.bo2,cl=C.tx;
        if(ch!==null){if(lt[i]===qs[cur].ans){bg=C.gd2;bd=C.g;cl=C.g;}else if(i===ch){bg=C.rd;bd=C.r;cl=C.r;}}
        return <button key={i} onClick={()=>ans(i)} disabled={ch!==null}
          style={{display:'block',width:'100%',padding:'11px 14px',borderRadius:9,border:`1px solid ${bd}`,background:bg,color:cl,fontSize:12,textAlign:'left',cursor:ch!==null?'default':'pointer',fontFamily:C.ff,marginBottom:7,transition:'all .15s',lineHeight:1.4}}>
          {op}
        </button>;
      })}
      {ch!==null&&<><div style={{background:C.s3,border:`1px solid ${C.bo2}`,borderRadius:9,padding:12,fontSize:11,color:C.tx3,lineHeight:1.7,marginBottom:14}}>💡 {qs[cur].exp}</div>
      <Btn v="primary" onClick={nxt} st={{width:'100%'}} ch={cur+1<qs.length?'Próxima →':'Ver Resultado →'}/></>}
    </div>}
    {ph==='result'&&<div style={{textAlign:'center',padding:'20px 0'}}>
      <div style={{fontFamily:C.fh,fontSize:76,color:sc2,lineHeight:1,marginBottom:6}}>{sc}/{qs.length}</div>
      <div style={{fontFamily:C.fm,fontSize:12,color:C.tx2,marginBottom:6}}>{pct}% de aproveitamento</div>
      <div style={{fontSize:13,color:C.tx3,marginBottom:22}}>{pct===100?'🏆 Perfeito!':pct>=60?'✅ Bom resultado!':pct>=40?'📚 Revise o material':'⚠️ Precisa estudar mais este curso'}</div>
      <div style={{display:'flex',gap:8}}>
        <Btn v="violet" onClick={()=>{sCur(0);sSc(0);sCh(null);sPh('loading');load();}} st={{flex:1}} ch="🔄 Tentar de novo"/>
        <Btn v="primary" onClick={onClose} st={{flex:1}} ch="✅ Fechar"/>
      </div>
    </div>}
  </Mod>;
}

