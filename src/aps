    <div>
      <div style={{fontSize:9,color:C.a,fontFamily:C.fm,letterSpacing:2,marginBottom:2}}>CONQUISTA DESBLOQUEADA!</div>
      <div style={{fontFamily:C.fh,fontSize:16,letterSpacing:1,color:C.wh}}>{badge.name}</div>
      <div style={{fontSize:10,color:C.tx3}}>{badge.desc} · <span style={{color:C.a}}>+{badge.xp} XP</span></div>
