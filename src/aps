// ═══ POMODORO ═══
function PomoPage({st,upd}){
  const [mode,sMode]=useState('work');const [secs,sSecs]=useState(25*60);const [run,sRun]=useState(false);const [sel,sSel]=useState('');
  const tRef=useRef(null);
  const M={work:{lb:'FOCO',dur:25*60,cl:C.g},short:{lb:'PAUSA',dur:5*60,cl:C.c},long:{lb:'DESCANSO',dur:15*60,cl:C.v}};
  const m=M[mode];
  useEffect(()=>{
    if(run){tRef.current=setInterval(()=>{sSecs(s=>{if(s<=1){clearInterval(tRef.current);sRun(false);if(mode==='work')upd(st=>({...st,pomo:(st.pomo||0)+1,pomoT:(st.pomoT||0)+1,hours:+((st.hours||0)+(25/60)).toFixed(2)}));return 0;}return s-1;});},1000);}
    return()=>clearInterval(tRef.current);
  },[run,mode]);
  function sw(nm){sMode(nm);sRun(false);sSecs(M[nm].dur);}
  const mm=String(Math.floor(secs/60)).padStart(2,'0'),ss=String(secs%60).padStart(2,'0');
  const R=85,circ=2*Math.PI*R,off=circ*(1-((1-secs/m.dur)));
  return <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20}}>
    <GC cl={m.cl} st={{display:'flex',flexDirection:'column',alignItems:'center',padding:'28px 20px'}}>
      <div style={{display:'flex',gap:6,marginBottom:24}}>
        {Object.entries(M).map(([k,v])=><button key={k} onClick={()=>sw(k)} style={{padding:'5px 12px',borderRadius:99,border:`1px solid ${mode===k?v.cl:C.bo2}`,background:mode===k?v.cl+'18':'transparent',color:mode===k?v.cl:C.tx3,fontSize:10,fontFamily:C.fm,cursor:'pointer',letterSpacing:.5}}>{v.lb}</button>)}
      </div>
      <svg width="190" height="190" style={{transform:'rotate(-90deg)'}}>
        <circle cx="95" cy="95" r={R} fill="none" stroke={C.bo2} strokeWidth="7"/>
        <circle cx="95" cy="95" r={R} fill="none" stroke={m.cl} strokeWidth="7" strokeDasharray={circ} strokeDashoffset={off} strokeLinecap="round" style={{transition:'stroke-dashoffset .5s',filter:`drop-shadow(0 0 5px ${m.cl}80)`}}/>
      </svg>
      <div style={{fontFamily:C.fh,fontSize:54,color:C.wh,letterSpacing:4,marginTop:-110,marginBottom:100,textAlign:'center'}}>{mm}:{ss}</div>
      <div style={{fontSize:11,color:m.cl,fontFamily:C.fm,letterSpacing:2,marginBottom:14}}>{m.lb} · {(st.pomo||0)} sessões hoje</div>
      {sel&&<div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:12}}>📖 {COURSES.find(c=>c.id===sel)?.name.slice(0,35)}</div>}
      <div style={{display:'flex',gap:8}}>
        {!run?<Btn v="primary" onClick={()=>sRun(true)} st={{minWidth:90}} ch="▶ Iniciar"/>:<Btn v="outline" onClick={()=>sRun(false)} st={{minWidth:90}} ch="⏸ Pausar"/>}
        <Btn v="outline" onClick={()=>{sRun(false);sSecs(m.dur);}} ch="↺"/>
      </div>
    </GC>
    <div style={{display:'flex',flexDirection:'column',gap:10}}>
      <GC st={{padding:14}}>
        <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:8,letterSpacing:1}}>ESTUDANDO</div>
        <select value={sel} onChange={e=>sSel(e.target.value)} style={{width:'100%',background:C.s3,border:`1px solid ${C.bo2}`,color:sel?C.wh:C.tx3,padding:'8px 10px',borderRadius:8,fontSize:12,outline:'none'}}>
          <option value="">— Selecionar Curso —</option>
          {COURSES.map(c=><option key={c.id} value={c.id}>{c.name}</option>)}
        </select>
      </GC>
      {[['🍅','Sessões Hoje',st.pomo||0],[' ⚡','Total Acumulado',st.pomoT||0],['⏱️','Horas de Foco',Math.round((st.pomoT||0)*25/60*10)/10+'h'],['🔥','Streak',`${st.streak||0} dias`]].map(([ic,lb,vl],i)=><GC key={i} st={{padding:'12px 16px',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
        <span style={{fontSize:12,color:C.tx3}}>{ic} {lb}</span>
        <span style={{fontFamily:C.fh,fontSize:22,color:C.g,letterSpacing:1}}>{vl}</span>
      </GC>)}
      <GC st={{padding:14}}>
        <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:8,letterSpacing:1}}>TÉCNICA POMODORO</div>
        {[['🍅','25min foco total — celular no silencioso'],['☕','5min pausa — levante e se hidrate'],['🌙','15min após 4 pomodoros'],['🔄','Repetir — a consistência bate o talento']].map(([ic,tx],i)=><div key={i} style={{display:'flex',gap:7,padding:'5px 0',fontSize:11,color:C.tx3}}><span>{ic}</span><span>{tx}</span></div>)}
      </GC>
    </div>
  </div>;
}

