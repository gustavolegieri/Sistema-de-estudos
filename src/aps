// ═══ STREAK CHECK-IN MODAL (NOVA FEATURE) ═══
function CheckInMod({st,upd,onClose}){
  const [done,setDone]=useState(false);
  const today=new Date().toISOString().split('T')[0];
  const alreadyChecked=st.lastStudy===today;

  function doCheckIn(){
    const yesterday=new Date();yesterday.setDate(yesterday.getDate()-1);
    const yISO=yesterday.toISOString().split('T')[0];
    const streak=(st.lastStudy===yISO||(st.streak||0)===0)?(st.streak||0)+1:1;
    upd(s=>({...s,lastStudy:today,streak,sD:{...s.sD,[today]:Math.max(s.sD?.[today]||0,1)}}));
    setDone(true);
  }

  return <Mod title="CHECK-IN DIÁRIO" sub={new Date().toLocaleDateString('pt-BR',{weekday:'long',year:'numeric',month:'long',day:'numeric'})} onClose={onClose} mw={420}>
    {alreadyChecked||done?
      <div style={{textAlign:'center',padding:'20px 0'}}>
        <div style={{fontSize:56,marginBottom:10}}>🔥</div>
        <div style={{fontFamily:C.fh,fontSize:32,color:C.a,letterSpacing:2,marginBottom:6}}>{st.streak||1} DIAS</div>
        <div style={{fontSize:12,color:C.tx3,marginBottom:20}}>Você fez check-in hoje! Continue a sequência amanhã.</div>
        {[3,7,14,30,60,100].map(goal=><div key={goal} style={{display:'flex',justifyContent:'space-between',padding:'6px 0',borderBottom:`1px solid ${C.bo}`}}>
          <span style={{fontSize:11,color:C.tx3}}>🎯 {goal} dias</span>
          <span style={{fontSize:11,color:(st.streak||0)>=goal?C.g:C.tx2,fontFamily:C.fm}}>{(st.streak||0)>=goal?'✅ DESBLOQUEADO':`${goal-(st.streak||0)} dias restantes`}</span>
        </div>)}
        <Btn v="primary" onClick={onClose} st={{width:'100%',marginTop:16}} ch="Fechar"/>
      </div>
      :
      <div style={{textAlign:'center',padding:'10px 0'}}>
        <div style={{fontSize:56,marginBottom:10}}>📅</div>
        <div style={{fontSize:14,color:C.wh,marginBottom:6}}>Você estudou hoje?</div>
        <div style={{fontSize:11,color:C.tx2,fontFamily:C.fm,marginBottom:20}}>Streak atual: <strong style={{color:C.a}}>{st.streak||0} dias</strong></div>
        <Btn v="primary" onClick={doCheckIn} st={{width:'100%',marginBottom:8}} ch="✅ Sim! Fiz meu check-in de hoje"/>
        <Btn v="outline" onClick={onClose} st={{width:'100%'}} ch="Não hoje"/>
      </div>
    }
  </Mod>;
}

