// ─── LEVELS ───
const LVS=[
  {n:'Iniciante',xp:0,ic:'🌱',cl:C.tx3},{n:'Aprendiz',xp:100,ic:'📖',cl:'#6ee7b7'},
  {n:'Dev Junior',xp:300,ic:'💻',cl:C.g},{n:'Dev Pleno',xp:700,ic:'⚡',cl:C.c},
  {n:'Dev Sênior',xp:1300,ic:'🔥',cl:C.v},{n:'Tech Lead',xp:2100,ic:'🚀',cl:'#f472b6'},
  {n:'Arquiteto',xp:3200,ic:'🏗️',cl:C.a},{n:'CTO',xp:5000,ic:'👑',cl:C.g},
];
function getLevel(xp){
  let lv=LVS[0],i=0;
  LVS.forEach((l,idx)=>{if(xp>=l.xp){lv=l;i=idx;}});
  const nx=LVS[i+1];
  return{...lv,idx:i,next:nx,prog:nx?Math.min(100,((xp-lv.xp)/(nx.xp-lv.xp))*100):100};
}

