async function aiCall(msgs,mt=800){
  const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:mt,messages:msgs})});
  const d=await r.json();
  if(d.error)throw new Error(d.error.message);
  return d.content?.map(c=>c.text||'').join('')||'';
}
function calcXP(s){
  let x=0;
  COURSES.forEach(c=>{if(s.cS[c.id]==='done')x+=80;else if(s.cS[c.id]==='wip')x+=15;});
  PROJECTS.forEach(p=>{const ps=s.pD?.[p.id];if(ps?.status==='done')x+=150;else if(ps?.status==='doing')x+=40;});
  x+=Object.values(s.qH||{}).flat().reduce((a,q)=>a+q.score*8,0);
  x+=(s.streak||0)*4;x+=(s.pomo||0)*2;
  (s.badges||[]).forEach(b=>{const bd=BADGES.find(x=>x.id===b);if(bd)x+=bd.xp;});
  Object.values(s.certs||{}).filter(Boolean).length*200;
  return x;
}
function chkBadges(s){
  const nb=[...(s.badges||[])];
  BADGES.forEach(b=>{if(!nb.includes(b.id)&&b.cond(s))nb.push(b.id);});
  return nb;
}

