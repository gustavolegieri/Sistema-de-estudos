// ═══ DIÁRIO DE ESTUDOS (NOVA FEATURE) ═══
function DiarioPage({st,upd}){
  const [entries,setEntries]=useState(st.diary||[]);
  const [mood,setMood]=useState('😊');
  const [hours,setHours]=useState('');
  const [text,setText]=useState('');
  const [topics,setTopics]=useState('');
  const [filter,setFilter]=useState('all');
  const [aiSummary,setAiSummary]=useState('');
  const [loadAI,setLoadAI]=useState(false);

  const MOODS=['😊','🔥','😤','😴','🤯','💪','😅','🎯'];

  function addEntry(){
    if(!text.trim())return;
    const entry={
      id:Date.now(),
      date:new Date().toLocaleDateString('pt-BR'),
      dateISO:new Date().toISOString().split('T')[0],
      mood,hours:parseFloat(hours)||0,
      text,topics,
      week:WEEKS.find(w=>{
        const d=new Date();
        const[s]=w.period.split(' – ');
        const pd=new Date(s.split('/').reverse().map((x,i)=>i===2?'20'+x:x).join('-'));
        return d>=pd;
      })?.w||1
    };
    const newEntries=[entry,...entries];
    setEntries(newEntries);
    upd(s=>({...s,diary:newEntries,
      hours:+(s.hours||0)+(entry.hours),
      streak:calcStreak(newEntries),
      lastStudy:entry.dateISO,
      sD:{...s.sD,[entry.dateISO]:Math.min(4,(s.sD?.[entry.dateISO]||0)+Math.ceil(entry.hours))}
    }));
    setText('');setTopics('');setHours('');setMood('😊');
  }

  function calcStreak(arr){
    if(!arr.length)return 0;
    const dates=[...new Set(arr.map(e=>e.dateISO))].sort().reverse();
    let streak=0;const today=new Date().toISOString().split('T')[0];
    let cur=new Date(today);
    for(const d of dates){
      const diff=(cur-new Date(d))/(1000*60*60*24);
      if(diff<=1){streak++;cur=new Date(d);cur.setDate(cur.getDate()-1);}
      else break;
    }
    return streak;
  }

  async function genAISummary(){
    if(!entries.length)return;
    setLoadAI(true);
    try{
      const last7=entries.slice(0,7).map(e=>`${e.date} | ${e.mood} | ${e.hours}h | ${e.text.slice(0,100)}`).join('\n');
      const tx=await aiCall([{role:'user',content:`Analise este diário de estudos de Gustavo (dev backend, 18 anos) e dê um feedback motivacional + dicas em 3 parágrafos curtos em PT-BR:\n${last7}`}],600);
      setAiSummary(tx);
    }catch{setAiSummary('Erro ao gerar análise. Tente novamente!');}
    setLoadAI(false);
  }

  const filtered=filter==='all'?entries:entries.filter(e=>e.mood===filter);
  const totalH=entries.reduce((a,e)=>a+e.hours,0);
  const avgH=entries.length?(totalH/entries.length).toFixed(1):0;

  return <div>
    <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:18,flexWrap:'wrap',gap:10}}>
      <div>
        <div style={{fontFamily:C.fh,fontSize:22,letterSpacing:2,color:C.wh}}>DIÁRIO DE ESTUDOS</div>
        <div style={{fontSize:11,color:C.tx2,fontFamily:C.fm}}>Registre seu progresso diário e acompanhe sua evolução</div>
      </div>
      <div style={{display:'flex',gap:8}}>
        <Bx t={`📝 ${entries.length} entradas`} cl={C.g}/>
        <Bx t={`⏱️ ${totalH.toFixed(1)}h total`} cl={C.c}/>
        <Bx t={`📊 ${avgH}h/dia`} cl={C.a}/>
      </div>
    </div>

    {/* ADD ENTRY */}
    <GC cl={C.g} st={{marginBottom:18}}>
      <div style={{fontFamily:C.fh,fontSize:15,letterSpacing:2,color:C.wh,marginBottom:14}}>+ NOVA ENTRADA</div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:12,marginBottom:12}}>
        <div>
          <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:5,letterSpacing:1}}>HUMOR</div>
          <div style={{display:'flex',gap:6,flexWrap:'wrap'}}>
            {MOODS.map(m=><button key={m} onClick={()=>setMood(m)}
              style={{fontSize:20,padding:'4px 8px',borderRadius:8,border:`2px solid ${mood===m?C.g:C.bo2}`,background:mood===m?C.gd2:'transparent',cursor:'pointer',transition:'all .15s'}}>
              {m}
            </button>)}
          </div>
        </div>
        <div>
          <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:5,letterSpacing:1}}>HORAS HOJE</div>
          <input value={hours} onChange={e=>setHours(e.target.value)} type="number" step="0.5" placeholder="Ex: 3.5"
            style={{width:'100%',background:C.s3,border:`1px solid ${C.bo2}`,color:C.wh,padding:'8px 10px',borderRadius:8,fontSize:14,outline:'none',fontFamily:C.fh,letterSpacing:2}}/>
        </div>
      </div>
      <div style={{marginBottom:10}}>
        <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:5,letterSpacing:1}}>TÓPICOS ESTUDADOS</div>
        <input value={topics} onChange={e=>setTopics(e.target.value)} placeholder="Ex: FastAPI, JWT, PostgreSQL..."
          style={{width:'100%',background:C.s3,border:`1px solid ${C.bo2}`,color:C.wh,padding:'8px 10px',borderRadius:8,fontSize:12,outline:'none',fontFamily:C.ff}}/>
      </div>
      <div style={{marginBottom:12}}>
        <div style={{fontSize:10,color:C.tx2,fontFamily:C.fm,marginBottom:5,letterSpacing:1}}>O QUE APRENDI / DIFICULDADES</div>
        <textarea value={text} onChange={e=>setText(e.target.value)} rows={3}
          placeholder="Descreva o que estudou, o que foi difícil, suas conquistas do dia..."
          style={{width:'100%',background:C.s3,border:`1px solid ${C.bo2}`,color:C.wh,padding:'9px 10px',borderRadius:8,fontSize:12,outline:'none',fontFamily:C.ff,resize:'vertical',lineHeight:1.6}}/>
      </div>
      <div style={{display:'flex',gap:8}}>
        <Btn v="primary" onClick={addEntry} dis={!text.trim()} st={{flex:1}} ch="📝 Registrar Entrada"/>
        <Btn v="violet" onClick={genAISummary} dis={loadAI||!entries.length} ch={loadAI?<Sp sz={14} cl="#c4b5fd"/>:'🤖 Análise IA'}/>
      </div>
    </GC>

    {/* AI SUMMARY */}
    {aiSummary&&<GC cl={C.v} st={{marginBottom:18,background:`linear-gradient(135deg,${C.vd2},${C.s2})`}}>
      <div style={{fontFamily:C.fh,fontSize:13,letterSpacing:2,color:'#c4b5fd',marginBottom:10}}>🤖 ANÁLISE IA DO SEU PROGRESSO</div>
      <div style={{fontSize:12,color:C.tx,lineHeight:1.8,whiteSpace:'pre-wrap'}}>{aiSummary}</div>
    </GC>}

    {/* FILTER */}
    <div style={{display:'flex',gap:6,marginBottom:14,flexWrap:'wrap'}}>
      <button onClick={()=>setFilter('all')} style={{padding:'4px 10px',borderRadius:99,border:`1px solid ${filter==='all'?C.g:C.bo2}`,background:filter==='all'?C.gd:'transparent',color:filter==='all'?C.g:C.tx3,fontSize:10,cursor:'pointer',fontFamily:C.fm}}>TODOS</button>
      {MOODS.map(m=><button key={m} onClick={()=>setFilter(filter===m?'all':m)}
        style={{padding:'4px 8px',borderRadius:99,border:`1px solid ${filter===m?C.g:C.bo2}`,background:filter===m?C.gd:'transparent',fontSize:14,cursor:'pointer'}}>
        {m}
      </button>)}
    </div>

    {/* ENTRIES */}
    <div style={{display:'flex',flexDirection:'column',gap:10}}>
      {filtered.length===0&&<div style={{textAlign:'center',padding:40,color:C.tx2,fontFamily:C.fm,fontSize:12}}>Nenhuma entrada ainda. Comece registrando seu estudo de hoje! 📝</div>}
      {filtered.map(e=><div key={e.id} className="afu" style={{background:C.s2,border:`1px solid ${C.bo}`,borderRadius:12,padding:16,borderLeft:`3px solid ${C.g}`}}>
        <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:8,flexWrap:'wrap',gap:8}}>
          <div style={{display:'flex',gap:8,alignItems:'center'}}>
            <span style={{fontSize:24}}>{e.mood}</span>
            <div>
              <div style={{fontFamily:C.fm,fontSize:11,color:C.g,letterSpacing:1}}>{e.date}</div>
              {e.topics&&<div style={{fontSize:10,color:C.tx2,marginTop:2}}>{e.topics}</div>}
            </div>
          </div>
          <div style={{display:'flex',gap:6}}>
            {e.hours>0&&<Bx t={`⏱️ ${e.hours}h`} cl={C.c}/>}
            <Bx t={`Semana ${e.week}`} cl={C.a}/>
          </div>
        </div>
        <div style={{fontSize:12,color:C.tx3,lineHeight:1.7}}>{e.text}</div>
      </div>)}
    </div>
  </div>;
}

